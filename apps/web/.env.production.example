# ════════════════════════════════════════════════════════════════════════
# LuxeMatch — production environment (Render web service: luxematch-web)
#
# Set each of these in the Render dashboard (or via render.yaml `sync: false`).
# Tags:
#   SERVER ONLY   — must NEVER reach the browser / a NEXT_PUBLIC_ var
#   FRONTEND SAFE — exposed to the browser bundle (NEXT_PUBLIC_*)
#   RUNTIME       — server config, not a secret
# ════════════════════════════════════════════════════════════════════════

# ── Shop tenancy ─────────────────────────────────────────────────────────
# SHOP_JEWELLER_ID is set PER DEVICE for kiosk mode (provision-shop writes it).
# For the multi-tenant public e-commerce deployment, leave it UNSET — the
# jeweller is resolved per request instead.
# RUNTIME
SHOP_JEWELLER_ID=
# SERVER ONLY — random >= 32 chars. Signs the lm_pin and lm_customer cookies.
LM_PIN_COOKIE_SECRET=
# RUNTIME — PIN session length in seconds (4h default).
LM_PIN_COOKIE_TTL_SECONDS=14400

# ── Supabase ─────────────────────────────────────────────────────────────
# FRONTEND SAFE
NEXT_PUBLIC_SUPABASE_URL=
# FRONTEND SAFE — anon/publishable key (RLS-restricted)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER ONLY — bypasses RLS. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudinary ───────────────────────────────────────────────────────────
# FRONTEND SAFE — used to build delivery URLs in the browser
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# RUNTIME — same value, read server-side
CLOUDINARY_CLOUD_NAME=
# SERVER ONLY
CLOUDINARY_API_KEY=
# SERVER ONLY — signs upload params. Never expose.
CLOUDINARY_API_SECRET=
# FRONTEND SAFE — optional. Set after running `pnpm upload:ar-demo-assets -- --apply`.
# Example:
# https://res.cloudinary.com/<cloud>/image/upload/c_limit,w_1400,q_auto:good,f_avif/AR-ITEMS-DEMO
NEXT_PUBLIC_AR_DEMO_ASSET_BASE_URL=

# ── OpenCLIP embedder (luxematch-embedder Render service) ────────────────
# RUNTIME — internal URL of the embedder service
EMBEDDER_URL=
# SERVER ONLY — bearer token; must match the embedder's EMBEDDER_API_KEY
EMBEDDER_API_KEY=

# ── Qdrant Cloud ─────────────────────────────────────────────────────────
# RUNTIME
QDRANT_URL=
# SERVER ONLY
QDRANT_API_KEY=
# RUNTIME
QDRANT_COLLECTION=luxematch_products

# ── Showcase visual search (Jewellery_AI / HF Space) ─────────────────────
# RUNTIME — optional; powers /api/search/jewellery-ai
JEWELLERY_AI_URL=https://botivate2026-jewellery.hf.space

# ── Transactional email (order confirmations) ────────────────────────────
# Optional for auth: Supabase Auth OTP emails use Supabase Dashboard SMTP.
# Required if you want LuxeMatch itself to send order confirmation emails.
# SERVER ONLY
SMTP_HOST=smtp.gmail.com
# RUNTIME
SMTP_PORT=587
# SERVER ONLY
SMTP_USER=
# SERVER ONLY
SMTP_PASS=
# SERVER ONLY
SMTP_FROM_EMAIL=
# RUNTIME
SMTP_FROM_NAME=LuxeMatch

# ── CORS / runtime ───────────────────────────────────────────────────────
# RUNTIME — comma-separated allow-list of browser origins. REQUIRED in prod
# (with NODE_ENV=production the API rejects unknown origins).
ALLOWED_ORIGINS=https://your-web-domain.example
# RUNTIME
NODE_ENV=production
