# ──────────────────────────────────────────────────────────────────────
# Shop tenancy (set per device by scripts/provision-shop.ts)
# ──────────────────────────────────────────────────────────────────────
SHOP_JEWELLER_ID=
LM_PIN_COOKIE_SECRET=
LM_PIN_COOKIE_TTL_SECONDS=14400

# ──────────────────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────────────
# Cloudinary
# ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=

# ──────────────────────────────────────────────────────────────────────
# OpenCLIP Embedder (apps/embedder)
# ViT-B-32 / laion2b_s34b_b79k / 512-d  — same as Jewellery_AI
# ──────────────────────────────────────────────────────────────────────
EMBEDDER_URL=http://localhost:8001
EMBEDDER_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Temporary showcase visual search adapter
# Points to the deployed Jewellery_AI / Hugging Face backend.
# Example: https://<space-owner>-<space-name>.hf.space
# ──────────────────────────────────────────────────────────────────────
JEWELLERY_AI_URL=

# ──────────────────────────────────────────────────────────────────────
# Qdrant
# ──────────────────────────────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=luxematch_products

# ──────────────────────────────────────────────────────────────────────
# CORS / runtime
# Leave ALLOWED_ORIGINS empty in dev (API allows all origins). In production
# set it to the deployed web origin(s), comma-separated.
# ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=
NODE_ENV=development
